# =============================================================================
# Paperclip AI — Komodo Stack environment
#
# In KOMODO: paste these (filled in) into the Stack's "Environment" box, or
# point env_file_path at a managed file. See komodo/stack.toml.
#
# For LOCAL/manual compose use: cp .env.example .env  and fill in below.
# =============================================================================

# ── Image ────────────────────────────────────────────────────────
# Pre-built server image (built & pushed by the Komodo Build resource).
PAPERCLIP_IMAGE=ghcr.io/OWNER/paperclip-server:latest

# ── Required ─────────────────────────────────────────────────────
# Auth secret — generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Public URL where Paperclip will be reachable (matches your reverse proxy host)
PAPERCLIP_PUBLIC_URL=https://paperclip.example.com

# ── Database ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=

# ── AI Agent API Keys (optional) ─────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Host / networking (optional) ─────────────────────────────────
# UID/GID to own the persistent volume — match the host user if using bind mounts.
USER_UID=1000
USER_GID=1000
